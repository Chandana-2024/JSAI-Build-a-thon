{
  "type": "module",
  "dependencies": {
    "@azure/openai": "^2.0.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "scripts": {
    "start": "concurrently \"npm run start:webapi\" \"npm run dev:webapp\"",
    "start:webapi": "cd packages/webapi && npm start",
    "dev:webapp": "cd packages/webapp && npm run dev"
  }
}
